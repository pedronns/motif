{
  "manifest_version": 3,
  "name": "Motif",
  "version": "1.1",
	"description": "Facilite sua prática musical no Youtube com uma ferramenta de contagem regressiva, mudança de tom e checkpoints salvos.",
  "icons": {
		"16": "icons/16.png",
		"48": "icons/48.png",
		"128": "icons/128.png"
	},
  "permissions": [
    "storage", 
    "management",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html"
  }
}